#include <SPI.h>
#include <SD.h>

// Pins
#define TRIG_PIN D1
#define ECHO_PIN D2
#define SD_CS D8

// Detection range
#define MIN_DISTANCE 30
#define MAX_DISTANCE 250

// Only this matters now
#define LEAVE_DELAY 3000  // 3 sec gap = new car

File myFile;
int carCount = 0;

void setup() {
  Serial.begin(115200);

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  if (!SD.begin(SD_CS)) {
    Serial.println("SD failed!");
    while (1);
  }

  myFile = SD.open("log.csv", FILE_WRITE);
  if (myFile) {
    myFile.println("Car#,Start_s,End_s,Duration_s");
    myFile.close();
  }
}

void loop() {
  static bool carPresent = false;
  static unsigned long startTime = 0;
  static unsigned long lastSeenTime = 0;

  long duration;
  float distance;

  // Trigger sensor
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);

  duration = pulseIn(ECHO_PIN, HIGH, 30000);

  if (duration == 0) {
    distance = -1;
  } else {
    distance = duration * 0.034 / 2;
  }

  unsigned long nowMillis = millis();
  unsigned long nowSec = nowMillis / 1000;

  // === OBJECT DETECTED ===
  if (distance > MIN_DISTANCE && distance < MAX_DISTANCE) {
    lastSeenTime = nowMillis;

    if (!carPresent) {
      carPresent = true;
      startTime = nowSec;
      carCount++;

      Serial.print("Car ");
      Serial.print(carCount);
      Serial.println(" started");
    }
  }

  // === OBJECT GONE FOR LONG ENOUGH ===
  if (carPresent && (nowMillis - lastSeenTime > LEAVE_DELAY)) {

    unsigned long endTime = nowSec;
    unsigned long durationSec = endTime - startTime;

    myFile = SD.open("log.csv", FILE_WRITE);
    if (myFile) {
      myFile.print(carCount);
      myFile.print(",");
      myFile.print(startTime);
      myFile.print(",");
      myFile.print(endTime);
      myFile.print(",");
      myFile.println(durationSec);
      myFile.close();
    }

    Serial.print("Car ");
    Serial.print(carCount);
    Serial.print(" ended. Duration: ");
    Serial.print(durationSec);
    Serial.println(" sec");

    carPresent = false;
  }

  delay(200);
}
